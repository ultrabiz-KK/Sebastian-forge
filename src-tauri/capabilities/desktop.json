{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "autostart:default",
    "global-shortcut:default",
    "dialog:default",
    "dialog:allow-open",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load"
  ]
}
